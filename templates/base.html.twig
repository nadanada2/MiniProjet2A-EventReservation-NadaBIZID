<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}EventApp{% endblock %}</title>
    <link rel="stylesheet" href="https://bootswatch.com/5/flatly/bootstrap.min.css">
    {% block stylesheets %}{% endblock %}
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_event_index') }}">🎫 EventApp</a>
        <div class="navbar-nav ms-auto">
            <a class="nav-link text-white" href="{{ path('app_event_index') }}">Événements</a>
            <a class="nav-link text-white" href="{{ path('app_event_new') }}">+ Créer</a>
            <a class="nav-link text-white" href="{{ path('login_page') }}">Connexion</a>
        </div>
    </div>
</nav>

<div class="container mt-4">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    {% block body %}{% endblock %}
</div>

{% block javascripts %}{% endblock %}
</body>
</html>