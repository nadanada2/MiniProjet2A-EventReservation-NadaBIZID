{% extends 'base.html.twig' %}

{% block title %}Réserver — {{ event.title }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h4>Réserver : {{ event.title }}</h4>
                <small class="text-muted">
                    📅 {{ event.date | date('d/m/Y à H:i') }} — 📍 {{ event.location }}
                </small>
            </div>
            <div class="card-body">
                {{ form_start(form) }}
                {{ form_row(form.name) }}
                {{ form_row(form.email) }}
                {{ form_row(form.phone) }}
                <div class="mt-3">
                    <button type="submit" class="btn btn-success w-100">Confirmer la réservation</button>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
        <a href="{{ path('app_event_show', {id: event.id}) }}" class="btn btn-secondary mt-2">Retour</a>
    </div>
</div>
{% endblock %}