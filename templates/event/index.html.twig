{% extends 'base.html.twig' %}

{% block title %}Événements{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Événements disponibles</h1>
    <a href="{{ path('app_event_new') }}" class="btn btn-success">+ Créer un événement</a>
</div>

{% if events is empty %}
    <div class="alert alert-info">Aucun événement pour le moment.</div>
{% else %}
    <div class="row">
        {% for event in events %}
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                {% if event.image %}
                    <img src="{{ event.image }}" class="card-img-top" alt="{{ event.title }}" style="height:200px;object-fit:cover">
                {% endif %}
                <div class="card-body">
                    <h5 class="card-title">{{ event.title }}</h5>
                    <p class="text-muted">
                        📅 {{ event.date | date('d/m/Y à H:i') }}<br>
                        📍 {{ event.location }}<br>
                        🪑 {{ event.seats }} places
                    </p>
                    <p class="card-text">{{ event.description | slice(0, 100) }}...</p>
                </div>
                <div class="card-footer d-flex gap-2">
                    <a href="{{ path('app_event_show', {id: event.id}) }}" class="btn btn-primary btn-sm">Voir</a>
                    <a href="{{ path('app_event_edit', {id: event.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
                    <form method="post" action="{{ path('app_event_delete', {id: event.id}) }}"
                          onsubmit="return confirm('Supprimer cet événement ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
                        <button class="btn btn-danger btn-sm">Supprimer</button>
                    </form>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}